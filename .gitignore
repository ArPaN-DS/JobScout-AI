# Keep important public project files tracked
!.gitignore
!.env.example
!requirements.txt
!manage.py
!README.md
!LICENSE
!CONTRIBUTING.md
!.github/
!.github/workflows/
!.github/workflows/*.yml

# Keep documentation tracked
!docs/
!docs/**/*.md

# Keep source templates and static assets tracked
!templates/
!templates/**/*.html
!static/
!static/css/
!static/css/**/*.css
!static/js/
!static/js/**/*.js

# Keep Django migrations tracked
!*/migrations/
!*/migrations/__init__.py
!*/migrations/*.py
