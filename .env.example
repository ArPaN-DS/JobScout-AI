# JobScout-AI Environment Configuration Example
# Copy this file to .env or run setup.bat / setup.sh to generate keys automatically.

DJANGO_SECRET_KEY=your-django-secret-key-here
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
DJANGO_DB_PATH=db.sqlite3

# Fernet symmetric encryption key for DB secrets. 
# Generate automatically via setup scripts or manually using:
# python generate_keys.py
FIELD_ENCRYPTION_KEY=your-fernet-encryption-key-here

GEMINI_API_KEY=
GEMINI_FLASH_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-2.5-pro

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

XAI_API_KEY=
XAI_MODEL=grok-3-mini

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

MOONSHOT_API_KEY=
MOONSHOT_MODEL=kimi-k2.5

DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-plus

OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

LLM_PROVIDER_ORDER=gemini,groq,openrouter,ollama,openai,anthropic,xai,deepseek,kimi,qwen
LLM_HTTP_TIMEOUT_SECONDS=45
LLM_PROVIDER_COOLDOWN_SECONDS=90

AUTO_SUBMIT_ENABLED=false

TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=

DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_IDS=

NOTIFICATION_WEBHOOK_URL=
MAX_RESUME_UPLOAD_MB=8
